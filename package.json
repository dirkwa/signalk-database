{
  "name": "signalk-database",
  "version": "0.1.0",
  "description": "SQLite library + admin UI for SignalK plugins: import { openPluginDb } from 'signalk-database' to get an isolated per-plugin database",
  "type": "module",
  "main": "dist/plugin/index.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build:plugin": "tsc -p tsconfig.plugin.json",
    "build:icon": "node -e \"require('node:fs').copyFileSync('app-icon.svg','public/app-icon.svg')\"",
    "build:webapp": "vite build && npm run build:icon",
    "build": "npm run build:plugin && npm run build:webapp",
    "watch": "tsc -p tsconfig.plugin.json --watch",
    "test": "tsc -p tsconfig.test.json && node --test 'dist-test/test/**/*.test.js'",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepack": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-database",
    "signalk-category-utility"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "Database",
    "appIcon": "./app-icon.svg"
  },
  "author": "Dirk",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-database.git"
  },
  "homepage": "https://github.com/dirkwa/signalk-database#readme",
  "bugs": {
    "url": "https://github.com/dirkwa/signalk-database/issues"
  },
  "files": [
    "dist/",
    "public/",
    "app-icon.svg",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "express": "^4.19.2",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
